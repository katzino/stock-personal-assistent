{
    "actorSpecification": 1,
    "fields": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
            "type": {
                "type": "string",
                "enum": ["company", "cryptocurrency"]
            },
            "ticker": {
                "type": "string"
            },
            "error": {
                "type": "string"
            },
            "sentiment_analysis": {
                "type": "object",
                "properties": {
                    "google": {
                        "type": "object",
                        "properties": {
                            "category": { "type": "string", "enum": ["Positive", "Neutral", "Negative"] },
                            "confidence": { "type": "number" },
                            "sentiment_score": { "type": "number" },
                            "reasoning": { "type": "string" }
                        }
                    },
                    "twitter": {
                        "type": "object",
                        "properties": {
                            "category": { "type": "string", "enum": ["Positive", "Neutral", "Negative"] },
                            "confidence": { "type": "number" },
                            "sentiment_score": { "type": "number" },
                            "reasoning": { "type": "string" }
                        }
                    }
                }
            },
            "market_summary": {
                "type": "object",
                "properties": {
                    "current_situation": { "type": "string" },
                    "top_discussed_topics": { "type": "array", "items": { "type": "string" } },
                    "recent_information": { "type": "array", "items": { "type": "string" } },
                    "investor_interest": { "type": "string" }
                }
            },
            "personalized_recommendation": {
                "type": "object",
                "properties": {
                    "persona_analysis": { "type": "string" },
                    "action": { "type": "string", "enum": ["Buy", "Hold", "Sell"] },
                    "summary": { "type": "string" },
                    "reasoning": { "type": "string" },
                    "potential_risks": { "type": "array", "items": { "type": "string" } }
                }
            }
        }
    },
    "views": {
        "overview": {
            "title": "Overview",
            "transformation": {
                "fields": [
                    "ticker",
                    "type",
                    "sentiment_analysis.google.category",
                    "sentiment_analysis.google.sentiment_score",
                    "sentiment_analysis.twitter.category",
                    "sentiment_analysis.twitter.sentiment_score",
                    "market_summary.current_situation",
                    "personalized_recommendation.action",
                    "personalized_recommendation.summary",
                    "error"
                ]
            },
            "display": {
                "component": "table",
                "properties": {
                    "ticker": {
                        "label": "Ticker",
                        "format": "text",
                        "description": "Stock or cryptocurrency ticker symbol analyzed."
                    },
                    "type": {
                        "label": "Type",
                        "format": "text",
                        "description": "Entity type — either 'company' or 'cryptocurrency'."
                    },
                    "sentiment_analysis.google.category": {
                        "label": "Google sentiment",
                        "format": "text",
                        "description": "Sentiment category derived from Google News articles (Positive, Neutral, or Negative)."
                    },
                    "sentiment_analysis.google.sentiment_score": {
                        "label": "Google score",
                        "format": "number",
                        "description": "Numeric sentiment score from Google News on a 0 (most negative) to 10 (most positive) scale."
                    },
                    "sentiment_analysis.twitter.category": {
                        "label": "Twitter sentiment",
                        "format": "text",
                        "description": "Sentiment category derived from X (Twitter) posts (Positive, Neutral, or Negative)."
                    },
                    "sentiment_analysis.twitter.sentiment_score": {
                        "label": "Twitter score",
                        "format": "number",
                        "description": "Numeric sentiment score from X (Twitter) on a 0 (most negative) to 10 (most positive) scale."
                    },
                    "market_summary.current_situation": {
                        "label": "Market situation",
                        "format": "text",
                        "description": "Short summary of the current market situation for the ticker."
                    },
                    "personalized_recommendation.action": {
                        "label": "Recommendation",
                        "format": "text",
                        "description": "Personalized actionable recommendation — Buy, Hold, or Sell."
                    },
                    "personalized_recommendation.summary": {
                        "label": "Recommendation summary",
                        "format": "text",
                        "description": "Recommendation summary tailored to the user's persona, risk tolerance, and investment horizon."
                    },
                    "error": {
                        "label": "Error",
                        "format": "text",
                        "description": "Error message populated when analysis for this ticker could not be completed."
                    }
                }
            }
        }
    }
}
